# Google Drive Configuration
# =============================
# Option 1: Path to your service account JSON file
# GOOGLE_CREDENTIALS_JSON=C:\path\to\your\credentials.json

# Option 2: JSON content as a single line (preferred for CI/CD)
# GOOGLE_CREDENTIALS_JSON={"type": "service_account", "project_id": "...", ...}

# Optional: ID of a specific folder to list/process (leave blank for root)
GOOGLE_CREDENTIALS_JSON=path/to/your/credentials.json
GOOGLE_DRIVE_FOLDER_ID=

# OpenAI Configuration
# ===========================
OPENAI_API_KEY=sk-your-api-key-here

# Application Configuration
# ===========================
LOG_LEVEL=INFO

# Cache directory (for storing analysis results)
CACHE_DIR=.cache

# Output directory (for exports)
OUTPUT_DIR=output

# Maximum spreadsheet size in MB
MAX_SPREADSHEET_SIZE_MB=100